# ============================================================
# NexCore SDK Repository .gitignore
# ============================================================

# OS / Editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.iml

# Secrets / Local config (公开仓库严防!)
.env
.env.*
*.key
*.pem
*.p12
credentials.json
secrets.json
config.local.*

# ============================================================
# Node.js
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp.*
package-lock.json.bak
dist/
build/
*.tsbuildinfo

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.tox/
.coverage
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/
.env/

# ============================================================
# Go
# ============================================================
bin/
*.test
*.out
vendor/
go.work.sum

# ============================================================
# PHP
# ============================================================
vendor/
composer.phar
composer.lock
.phpunit.result.cache

# ============================================================
# CI / docs
# ============================================================
coverage/
.nyc_output/
htmlcov/
docs/_build/
.tmp/

{
  "name": "nexcore/sdk",
  "description": "Official Tovanix (formerly NexCore) PHP SDK — Payment / Withdraw / Exchange / Energy / SMTP / Account / VCard. Covers all v1 public API endpoints.",
  "type": "library",
  "license": "MIT",
  "version": "3.2.0",
  "keywords": ["nexcore", "tovanix", "payment", "crypto", "tron", "usdt", "smtp", "sdk", "trc20", "withdraw", "vcard", "account"],
  "require": {
    "php": ">=7.4",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-openssl": "*"
  },
  "autoload": {
    "psr-4": {
      "NexCore\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "NexCore\\Examples\\": "examples/"
    }
  },
  "support": {
    "issues": "https://github.com/DoBestone/nexcore-sdk/issues",
    "source": "https://github.com/DoBestone/nexcore-sdk",
    "docs": "https://github.com/DoBestone/nexcore-sdk/tree/main/php"
  }
}
